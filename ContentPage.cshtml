@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.ContentPage>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;

@{
    Layout = "_layout.cshtml";
    var pageTitle = !string.IsNullOrEmpty(Model.PageTitle) ? Model.PageTitle : Model.Name;
}

<main id="main">
    <div class="container-fluid">
        <div class="row justify-content-center">
            @if (!string.IsNullOrEmpty(pageTitle))
            {
                <h1 class="d-flex justify-content-center text-center fw-bold fs-0 text-shadow bg-primary text-white py-5">@pageTitle</h1>
            }
            @if (!string.IsNullOrEmpty(Model?.PageSubtitle))
            {
                <h2 class="d-flex justify-content-center text-center fw-semibold fs-3 text-shadow bg-primary text-white pb-5 mt-0">@Model.PageSubtitle</h2>
            }

            @await Html.PartialAsync("site/breadcrumb")

            <div class="col">
                @Html.GetBlockListHtml(Model?.MainContent)
            </div>
        </div>
    </div>
</main>