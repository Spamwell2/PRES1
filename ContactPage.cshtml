@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.ContactPage>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@using PRES1.Models;
@using Umbraco.Cms.Core.Models.PublishedContent
@using Umbraco.Extensions

@{
    Layout = "_layout.cshtml";
    var pageTitle = !string.IsNullOrEmpty(Model.PageTitle) ? Model.PageTitle : Model.Name;
    var contactTextDictionary = Umbraco.GetDictionaryValue("ContactText");
    var contactText = contactTextDictionary?.Replace("\r\n", "<br>").Replace("\n", "<br>");
}

<main id="main">
    @if (!string.IsNullOrEmpty(pageTitle))
    {
        <h1 class="d-flex justify-content-center text-center fw-bold fs-0 text-shadow bg-primary text-white py-5">@pageTitle</h1>
    }
    <div class="container-fluid">
        <div class="row justify-content-center">
            @await Html.PartialAsync("site/breadcrumb")

            <!-- Contact Info -->
            <div class="col-md-3">
                <p>@Html.Raw(contactText)</p>
            </div>

            <!-- Contact Form -->
            <div class="col-md-6">
                <div class="col-lg-10">
                    <div class="contact-form">
                        @await Html.PartialAsync("~/Views/Partials/ContactForm.cshtml", new ContactFormViewModel())
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Footer {
    <script src="/assets/js/customform.js" asp-append-version="true"></script>
}
