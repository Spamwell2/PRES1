@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
	Layout = null;
	var currentCulture = Umbraco.CultureDictionary.Culture.Name; // Fetch the current culture.
	var lang = currentCulture == "cy-GB" ? currentCulture : "en-GB"; // Set the language based on the culture.
	ViewData["lang"] = lang; // Passes the lang variable to ViewData
}
<!DOCTYPE html>
<html lang="@lang" class="no-js" dir="ltr">
<head>

	<!-- Meta Data -->
	@await Html.PartialAsync("site/metaData")

	<!-- Silktide Cookie Banner -->
	@await Html.PartialAsync("site/cookieBanner")

	<!-- Bootstrap References  -->
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
	<!-- fonts -->
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Allan:wght@400;700&family=Domine:wght@400..700&family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap" rel="stylesheet">
	<link rel="stylesheet" href="/assets/fonts/museo.css">
	<!-- Swiper -->
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
	<!-- Lightbox -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/fancybox/3.5.7/jquery.fancybox.min.css" />
	<!-- fontawesome References  -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" integrity="sha512-Kc323vGBEqzTmouAECnVceyQqyqdsSiqLQISBL29aUW4U/M7pSPA/gEUZQqv1cwx4OnYxTxve5UMg5GT6L4JJg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
	<!-- CSS -->
	<link rel="stylesheet" href="/assets/css/styles.css" asp-append-version="true">
	<link rel="stylesheet" href="/assets/css/custom.css" asp-append-version="true">

	@RenderSection("Header", false)

</head>

<body class="custom-cursor">

	<a href="#main" class="skip-to-content">@Umbraco.GetDictionaryValue("SkipToMain")</a>

	@await Html.PartialAsync("site/header")

	@RenderBody()

	@await Html.PartialAsync("site/footer")

	@await Html.PartialAsync("site/mobilenav")

	<button id="scrollButton" onclick="scrollToTop()" aria-label="@Umbraco.GetDictionaryValue("ScrollToTop")">&#x2191;</button>

	<!-- JS -->
	<!-- Bootstrap -->
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
	<!-- jQuery -->
	<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
	<!-- Swiper -->
	<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
	<!-- Lightbox -->
	<script src="https://cdnjs.cloudflare.com/ajax/libs/fancybox/3.5.7/jquery.fancybox.min.js"></script>
	<!-- ReciteMe -->
	<script src='/assets/js/reciteme.js' defer></script>
	<!-- Custom JS -->
	<script src="/assets/js/scripts.js" asp-append-version="true" defer></script>
	<script src="/assets/js/scrolltotop.js" defer></script>
	<script src="/assets/js/cookie-manager.js" defer asp-append-version="true"></script>

	@RenderSection("Footer", false)

</body>
</html>
